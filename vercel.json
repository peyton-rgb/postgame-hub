{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/pitches/generate/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/heroes/render/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/recap-intake",
      "schedule": "*/10 * * * *"
    }
  ]
}
