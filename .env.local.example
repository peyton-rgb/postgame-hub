# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side / scripts only (bypasses RLS, never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: custom domain for recap URLs
# NEXT_PUBLIC_SITE_URL=https://postgame.co

# Athlete app — Google Drive root folder ("Campaigns") for athlete deal folders.
# When unset (or GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON missing), athlete Drive
# folders are skipped (no-op) and uploads still work. See src/lib/athlete-drive.ts.
# ATHLETE_DRIVE_ROOT_FOLDER_ID=your-drive-folder-id

# Auto editor — content scoring (Anthropic vision). ANTHROPIC_API_KEY enables
# real scoring; without it the curator returns clearly-labelled stub results.
# AUTO_EDITOR_MODEL overrides the model (default claude-opus-4-8; e.g. set to
# claude-sonnet-4-6 to cut cost on large photo batches).
# ANTHROPIC_API_KEY=sk-ant-...
# AUTO_EDITOR_MODEL=claude-opus-4-8

# Slack Bot token (xoxb-...) — reads the "Recap Queue List" intake source.
# Used by src/lib/slack-recap-queue.ts and scripts/list-outstanding-recaps.ts.
# SLACK_BOT_TOKEN=xoxb-...

# Manager layer — Slack delivery for manager notifications. UNSET = no-op
# (in-app notifications still fire). Create an Incoming Webhook in Slack and put
# its URL here. SLACK_DRY_RUN=1 logs the payload instead of sending (testing).
# SLACK_EVENTS optionally limits which event types post (comma-separated).
# NEVER commit a real webhook. See docs/manager-layer/SLACK-SETUP.md.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_DRY_RUN=
# SLACK_EVENTS=
# NEXT_PUBLIC_SITE_URL=https://postgame-hub.vercel.app   # used for absolute Slack links

# Manager layer — deadline-check cron. Set a secret, then point a Vercel cron at
# GET /api/staff/manager/check-deadlines with header x-cron-key (or ?key=).
# CRON_SECRET=

# Athlete app — PayPal payouts (STUBBED; not yet wired to live money).
# Add real credentials before enabling payout execution.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
